{
  "name": "@ledra/workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Ledra monorepo workspace",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "ledra": "npm exec --workspace @ledra/cli ledra --",
    "lint": "eslint . --ext .ts,.tsx,.mts,.cts",
    "package:cloudflare": "node scripts/package-cloudflare.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run build --workspaces --if-present && node --test tests/**/*.test.mjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
