name: ledra-preview

on:
  pull_request:
    types: [opened, synchronize, reopened, closed]

permissions:
  contents: read
  pull-requests: write

env:
  LEDRA_ENGINE_REPO: viasnake/ledra
  LEDRA_ENGINE_REF: v0.1.0
  LEDRA_REGISTRY_PATH: registry
  CLOUDFLARE_WORKER_BASENAME: ledra-registry

jobs:
  build-preview:
    if: github.event.action != 'closed' && github.event.pull_request.head.repo.full_name == github.repository
    runs-on: ubuntu-latest
    outputs:
      worker_name: ${{ steps.worker-name.outputs.value }}
    steps:
      - name: Checkout data repository
        uses: actions/checkout@v4

      - name: Checkout Ledra engine
        uses: actions/checkout@v4
        with:
          repository: ${{ env.LEDRA_ENGINE_REPO }}
          ref: ${{ env.LEDRA_ENGINE_REF }}
          path: engine

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20

      - name: Install dependencies
        run: npm install
        working-directory: engine

      - name: Build engine
        run: npm run build
        working-directory: engine

      - name: Run tests
        run: npm test
        working-directory: engine

      - name: Validate registry data
        run: npm exec --workspace @ledra/cli ledra -- validate --registry "${{ github.workspace }}/${{ env.LEDRA_REGISTRY_PATH }}"
        working-directory: engine

      - name: Export bundle
        run: npm exec --workspace @ledra/cli ledra -- export --registry "${{ github.workspace }}/${{ env.LEDRA_REGISTRY_PATH }}" --out ".artifacts/cloudflare/bundle.json"
        working-directory: engine

      - name: Resolve engine commit SHA
        id: engine-sha
        run: printf 'sha=%s\n' "$(git rev-parse HEAD)" >> "$GITHUB_OUTPUT"
        working-directory: engine

      - name: Resolve preview worker name
        id: worker-name
        run: printf 'value=%s\n' "${CLOUDFLARE_WORKER_BASENAME}-pr-${PR_NUMBER}" >> "$GITHUB_OUTPUT"
        working-directory: engine
        env:
          PR_NUMBER: ${{ github.event.number }}

      - name: Package Cloudflare assets
        run: >-
          node scripts/package-cloudflare.mjs
          --bundle .artifacts/cloudflare/bundle.json
          --out deploy/cloudflare/public
          --data-repo "${{ github.repository }}"
          --data-ref "${{ github.event.pull_request.head.ref }}"
          --data-commit "${{ github.event.pull_request.head.sha }}"
          --registry-path "${{ env.LEDRA_REGISTRY_PATH }}"
          --engine-repo "${{ env.LEDRA_ENGINE_REPO }}"
          --engine-ref "${{ env.LEDRA_ENGINE_REF }}"
          --engine-commit "${{ steps.engine-sha.outputs.sha }}"
        working-directory: engine

      - name: Upload packaged assets
        uses: actions/upload-artifact@v4
        with:
          name: ledra-preview-package
          path: engine/deploy/cloudflare/public

  deploy-preview:
    if: github.event.action != 'closed' && github.event.pull_request.head.repo.full_name == github.repository
    needs: build-preview
    runs-on: ubuntu-latest
    environment: preview
    steps:
      - name: Checkout Ledra engine
        uses: actions/checkout@v4
        with:
          repository: ${{ env.LEDRA_ENGINE_REPO }}
          ref: ${{ env.LEDRA_ENGINE_REF }}
          path: engine

      - name: Download packaged assets
        uses: actions/download-artifact@v4
        with:
          name: ledra-preview-package
          path: engine/deploy/cloudflare/public

      - name: Render preview Wrangler config
        run: >-
          node scripts/render-preview-wrangler.mjs
          --input deploy/cloudflare/wrangler.toml.example
          --output deploy/cloudflare/wrangler.toml
          --worker-name "${{ needs.build-preview.outputs.worker_name }}"
        working-directory: engine

      - name: Deploy preview to Cloudflare
        uses: cloudflare/wrangler-action@v3
        with:
          apiToken: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          accountId: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
          workingDirectory: engine/deploy/cloudflare
          command: deploy

      - name: Comment preview URL
        uses: actions/github-script@v7
        with:
          script: |
            const workerName = `${process.env.CLOUDFLARE_WORKER_BASENAME}-pr-${context.payload.pull_request.number}`;
            const previewUrl = `https://${workerName}.${process.env.CLOUDFLARE_ACCOUNT_SUBDOMAIN}.workers.dev`;
            const body = [
              'Ledra preview deployed.',
              '',
              `- URL: ${previewUrl}`,
              `- Data commit: ${context.payload.pull_request.head.sha}`,
              `- Engine ref: ${process.env.LEDRA_ENGINE_REF}`
            ].join('\n');
            await github.rest.issues.createComment({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.issue.number,
              body
            });
        env:
          CLOUDFLARE_ACCOUNT_SUBDOMAIN: your-account-subdomain

  delete-preview:
    if: github.event.action == 'closed' && github.event.pull_request.head.repo.full_name == github.repository
    runs-on: ubuntu-latest
    environment: preview
    steps:
      - name: Checkout Ledra engine
        uses: actions/checkout@v4
        with:
          repository: ${{ env.LEDRA_ENGINE_REPO }}
          ref: ${{ env.LEDRA_ENGINE_REF }}
          path: engine

      - name: Render preview Wrangler config
        run: >-
          node scripts/render-preview-wrangler.mjs
          --input deploy/cloudflare/wrangler.toml.example
          --output deploy/cloudflare/wrangler.toml
          --worker-name "${{ env.CLOUDFLARE_WORKER_BASENAME }}-pr-${{ github.event.number }}"
        working-directory: engine

      - name: Delete preview worker
        uses: cloudflare/wrangler-action@v3
        with:
          apiToken: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          accountId: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
          workingDirectory: engine/deploy/cloudflare
          command: delete --force
